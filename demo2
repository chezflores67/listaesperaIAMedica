let currentTour = null;
let currentStep = 0;
let tourSteps = [];

function showSection(name) {
  ['lista','cancelacion','agregar','whatsapp','reportes','airtable','prompt'].forEach(s => {
    const el = document.getElementById('section-'+s);
    if(el) el.classList.add('hidden');
    const nav = document.getElementById('nav-'+s);
    if(nav) nav.classList.remove('active');
  });
  const section = document.getElementById('section-'+name);
  if(section) section.classList.remove('hidden');
  const nav = document.getElementById('nav-'+name);
  if(nav) nav.classList.add('active');
}

function startTour(type) {
  currentTour = type;
  currentStep = 0;
  tourSteps = TOURS[type];
  renderStep();
  document.getElementById('overlay').classList.remove('hidden');
}

function renderStep() {
  const step = tourSteps[currentStep];
  const total = tourSteps.length;
  
  // Show section if needed
  if(step.section) showSection(step.section);
  
  // Highlight element
  const ring = document.getElementById('highlight-ring');
  if(step.highlight) {
    const el = document.getElementById(step.highlight);
    if(el) {
      const rect = el.getBoundingClientRect();
      ring.style.left = (rect.left - 8) + 'px';
      ring.style.top = (rect.top - 8) + 'px';
      ring.style.width = (rect.width + 16) + 'px';
      ring.style.height = (rect.height + 16) + 'px';
      ring.classList.remove('hidden');
    }
  } else {
    ring.classList.add('hidden');
  }

  // Persona label
  const personaMap = {
    doctor: { label: '👨‍⚕️ Para el Médico', cls: 'persona-doctor' },
    asistente: { label: '👩‍💼 Para Asistentes', cls: 'persona-asistente' },
    ambos: { label: '👥 Para Todos', cls: 'persona-ambos' }
  };
  const p = personaMap[step.persona] || personaMap.ambos;

  // Progress dots
  const dots = Array.from({length: total}, (_, i) => {
    const cls = i < currentStep ? 'done' : (i === currentStep ? 'active' : '');
    return `<div class="prog-dot ${cls}"></div>`;
  }).join('');

  const isLast = currentStep === total - 1;
  const isFirst = currentStep === 0;

  const card = document.getElementById('tour-card');
  card.innerHTML = `
    <div class="tour-badge">${step.badge}</div>
    <div class="tour-persona"><span class="persona-tag ${p.cls}">${p.label}</span></div>
    <h2>${step.title}</h2>
    ${step.content}
    <div class="tour-progress">${dots}</div>
    <div class="tour-nav">
      <span class="step-counter">Paso ${currentStep + 1} de ${total}</span>
      <div style="display:flex;gap:8px">
        ${!isFirst ? `<button class="btn-nav btn-prev" onclick="prevStep()">← Anterior</button>` : ''}
        ${isLast ? 
          `<button class="btn-nav btn-finish" onclick="finishTour()">✓ Finalizar tour</button>` :
          `<button class="btn-nav btn-next" onclick="nextStep()">Siguiente →</button>`
        }
      </div>
    </div>
  `;

  // Animate card
  card.style.animation = 'none';
  requestAnimationFrame(() => { card.style.animation = 'cardIn 0.35s cubic-bezier(.34,1.56,.64,1)'; });
}

function nextStep() {
  if(currentStep < tourSteps.length - 1) { currentStep++; renderStep(); }
}
function prevStep() {
  if(currentStep > 0) { currentStep--; renderStep(); }
}
function finishTour() {
  document.getElementById('overlay').classList.add('hidden');
  document.getElementById('highlight-ring').classList.add('hidden');
  showWelcome();
}

function showWelcome() {
  const card = document.getElementById('tour-card');
  document.getElementById('highlight-ring').classList.add('hidden');
  card.innerHTML = `
    <div id="welcome-card">
      <div style="font-size:48px;margin-bottom:12px">🏥</div>
